rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function isDocente() {
      return isAuthenticated() && getUserData().rol == 'docente';
    }

    function isAlumno() {
      return isAuthenticated() && getUserData().rol == 'alumno';
    }

    // autores: lectura pública, escritura solo docente
    match /autores/{id} {
      allow read: if true;
      allow write: if isDocente();
    }

    // recursos: lectura pública, escritura solo docente
    match /recursos/{id} {
      allow read: if true;
      allow write: if isDocente();
    }

    // consignas: lectura pública (alumnos filtran por curso en el cliente), escritura solo docente
    match /consignas/{id} {
      allow read: if true;
      allow write: if isDocente();
    }

    // entregas: docente lee todas, alumno solo las suyas
    match /entregas/{id} {
      allow read: if isDocente() || (isAlumno() && resource.data.alumnoId == request.auth.uid);
      allow create: if isAlumno() && request.resource.data.alumnoId == request.auth.uid;
      allow update: if isAlumno() && resource.data.alumnoId == request.auth.uid;
      allow delete: if isDocente();
    }

    // usuarios: cada usuario lee y actualiza su propio doc, docente lee todos
    match /usuarios/{uid} {
      allow read: if isDocente() || (isAuthenticated() && request.auth.uid == uid);
      allow create, update: if isAuthenticated() && request.auth.uid == uid;
      allow delete: if isDocente();
    }
  }
}
